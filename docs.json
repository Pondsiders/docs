            "pages": [
              "index"
            ]
          }
        ]
      },
      {
        "tab": "Alpha SDK",
        "groups": [
          {
            "group": "Overview",
            "pages": [
              "alpha-sdk/index",
              "alpha-sdk/architecture"
            ]
          },
          {
            "group": "Core",
            "pages": [
              "alpha-sdk/client",
              "alpha-sdk/system-prompt",
              "alpha-sdk/compact-proxy"
            ]
          },
          {
            "group": "Memory",
            "pages": [
              "alpha-sdk/memory-recall",
              "alpha-sdk/memory-suggest",
              "alpha-sdk/cortex-tools"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "GitHub",
